{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "customManagers": [
    {
      "description": "Track the Terraform version pinned in .terraform-version",
      "customType": "regex",
      "managerFilePatterns": ["/^\\.terraform-version$/"],
      "matchStrings": ["(?<currentValue>.*)"],
      "depNameTemplate": "hashicorp/terraform",
      "datasourceTemplate": "github-releases"
    }
  ]
}
